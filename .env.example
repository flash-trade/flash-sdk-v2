# Copy to .env and adjust. Consumed by scripts/ (and overrides tests/ defaults).
#
# NOTE: deploy-scripts/ do NOT read CLUSTER/RPC_URL/ER_ENDPOINT from here — they
# infer the cluster from the target pool name and take endpoints from
# config/<cluster>.ts. Override a deploy run with DEPLOY_RPC_URL /
# DEPLOY_ER_ENDPOINT (e.g. a keyed mainnet RPC). They still use WALLET + SEND.
CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com
ER_ENDPOINT=https://devnet-as.magicblock.app
WALLET=~/.config/solana/id.json
# SESSION_KEY=~/session.json
POOL=devnet.1
TARGET_SYMBOL=SOL
COLLATERAL_SYMBOL=USDC

# Set SEND=1 to make mutating runners actually submit (default: dry-run)
# SEND=1
